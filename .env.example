# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=legal
POSTGRES_PASSWORD=legal
POSTGRES_DB=contracts
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── PGAdmin ─────────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=legal-documents
MINIO_USE_SSL=false

# ── EU Data Portal ────────────────────────────────────────────────────────────
EUROPA_API_BASE=https://data.europa.eu/api/hub/search/search

# ── Agent ─────────────────────────────────────────────────────────────────────
# MAX_RETRIES controls how many times the agent re-tries a failed extraction step
AGENT_MAX_RETRIES=2

# ── Google Docs (optional) ────────────────────────────────────────────────────
# Path to a GCP service account JSON key with Drive read access.
# Leave blank to use Application Default Credentials (e.g. on GCP VMs).
GOOGLE_SERVICE_ACCOUNT_JSON='secrets/6878e636e89d.json'
