# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=legal
POSTGRES_PASSWORD=legal
POSTGRES_DB=contracts
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432

# ── pgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_HOST_PORT=5050

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=legal-documents
MINIO_USE_SSL=false

# ── EU Data Portal ────────────────────────────────────────────────────────────
EUROPA_API_BASE=https://data.europa.eu/api/hub/search/search
EUROPA_QUERY=Digital Services OR Data Protection
EUROPA_LIMIT=5

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_MAX_RETRIES=2
SLACK_WEBHOOK_URL=

# ── Google Docs (optional) ────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=/app/secrets/gcp-service-account.json